{
  "name": "greenfield",
  "displayName": "GreenField",
  "description": "Detects unused JSON fields between frontend and backend codebases.",
  "version": "0.0.1",
  "publisher": "greenfield",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:greenfield.scanWorkspace",
    "workspaceContains:**/*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "greenfield.scanWorkspace",
        "title": "GreenField: Scan Workspace"
      },
      {
        "command": "greenfield.showEndpoints",
        "title": "GreenField: Show Endpoint Registry"
      }
    ],
    "configuration": {
      "title": "GreenField",
      "properties": {
        "greenfield.include": {
          "type": "array",
          "default": [
            "**/*.{ts,tsx,js,jsx,py,java,go}"
          ],
          "description": "Glob patterns for files scanned by GreenField."
        },
        "greenfield.exclude": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.next/**",
            "**/coverage/**",
            "**/__pycache__/**",
            "**/.venv/**",
            "**/target/**",
            "**/vendor/**"
          ],
          "description": "Glob patterns excluded from GreenField scans."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "tsc -p tsconfig.test.json && mocha 'dist-test/test/suite/**/*.test.js' --timeout 10000"
  },
  "dependencies": {
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.110.0",
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
